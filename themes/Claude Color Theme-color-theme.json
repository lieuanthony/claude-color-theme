{
    "name": "Claude Aether",
    "type": "dark",
    "colors": {
        // --- General UI ---
        "editor.background": "#282624",
        "editor.foreground": "#EAE8E1",
        "editor.lineHighlightBackground": "#312E2B",
        "editor.selectionBackground": "#D18B7130",
        "editor.inactiveSelectionBackground": "#D18B7115",
        "editorCursor.foreground": "#D18B71",
        "editorWhitespace.foreground": "#4A4540",
        "editorIndentGuide.background1": "#3A3632",
        "editorIndentGuide.activeBackground1": "#D18B7160",
        "editorLineNumber.foreground": "#6B6560",
        "editorLineNumber.activeForeground": "#C5C2B9",

        "activityBar.background": "#1E1C1A",
        "activityBar.foreground": "#C5C2B9",
        "activityBar.inactiveForeground": "#5A544E",
        "activityBarBadge.background": "#D18B71",
        "activityBarBadge.foreground": "#FFFFFF",

        "sideBar.background": "#22201E",
        "sideBar.foreground": "#C5C2B9",
        "sideBarTitle.foreground": "#8E8880",
        "sideBarSectionHeader.background": "#282624",
        "sideBarSectionHeader.foreground": "#EAE8E1",

        "list.activeSelectionBackground": "#D18B7120",
        "list.activeSelectionForeground": "#EAE8E1",
        "list.inactiveSelectionBackground": "#312E2B",
        "list.hoverBackground": "#312E2B80",

        "titleBar.activeBackground": "#1E1C1A",
        "titleBar.activeForeground": "#EAE8E1",
        "tab.activeBackground": "#282624",
        "tab.inactiveBackground": "#1E1C1A",
        "tab.activeForeground": "#EAE8E1",
        "tab.inactiveForeground": "#8E8880",
        "tab.border": "#1E1C1A",
        "tab.activeBorderTop": "#D18B71",

        "statusBar.background": "#1E1C1A",
        "statusBar.foreground": "#C5C2B9",

        // --- Terminal (Muted & Desaturated) ---
        "terminal.background": "#22201E",
        "terminal.foreground": "#EAE8E1",
        "terminal.ansiBlack": "#282624",
        "terminal.ansiRed": "#D18B71",
        "terminal.ansiGreen": "#8FAF8F",
        "terminal.ansiYellow": "#D0AC8B",
        "terminal.ansiBlue": "#81A1C1",
        "terminal.ansiMagenta": "#B48EAD",
        "terminal.ansiCyan": "#88C0D0",
        "terminal.ansiWhite": "#EAE8E1",

        "input.background": "#312E2B",
        "input.border": "#423E3A",
        "button.background": "#D18B71",
        "button.hoverBackground": "#E09A80",
        "focusBorder": "#D18B7160"
    },
    "tokenColors": [
        {
            "name": "Comment",
            "scope": ["comment", "punctuation.definition.comment"],
            "settings": {
                "fontStyle": "italic",
                "foreground": "#7D7670"
            }
        },
        {
            "name": "String",
            "scope": ["string", "markup.inserted"],
            "settings": {
                "foreground": "#98B398"
            }
        },
        {
            "name": "Number, Constant",
            "scope": ["constant.numeric", "constant.language", "constant.character"],
            "settings": {
                "foreground": "#88B0B0"
            }
        },
        {
            "name": "Keyword, Storage",
            "scope": ["keyword", "storage.type", "storage.modifier"],
            "settings": {
                "foreground": "#D18B71"
            }
        },
        {
            "name": "Function",
            "scope": ["entity.name.function", "meta.function-call", "support.function"],
            "settings": {
                "foreground": "#92ACC7"
            }
        },
        {
            "name": "Class, Type",
            "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"],
            "settings": {
                "foreground": "#D4B496"
            }
        },
        {
            "name": "Operator, Punctuation",
            "scope": ["keyword.operator", "punctuation"],
            "settings": {
                "foreground": "#A7A299"
            }
        },
        {
            "name": "Variable",
            "scope": ["variable", "variable.other"],
            "settings": {
                "foreground": "#EAE8E1"
            }
        }
    ]
}