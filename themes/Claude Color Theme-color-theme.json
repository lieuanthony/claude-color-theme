{
    "name": "Claude Color Theme",
    "type": "dark",
    "colors": {
        "editor.background": "#30302e",
        "editor.foreground": "#d6d5d2",
        "editor.lineHighlightBackground": "#383634",
        "editor.selectionBackground": "#d9785730",
        "editor.inactiveSelectionBackground": "#d9785715",
        "editorCursor.foreground": "#d97857",
        "editorWhitespace.foreground": "#4A4540",
        "editorIndentGuide.background1": "#3A3632",
        "editorIndentGuide.activeBackground1": "#d9785760",
        "editorLineNumber.foreground": "#6B6560",
        "editorLineNumber.activeForeground": "#d6d5d2",
        "editorError.foreground": "#e57777",
        "editorWarning.foreground": "#fbae60",
        "editorInfo.foreground": "#70b8ff",

        "activityBar.background": "#252422",
        "activityBar.foreground": "#d6d5d2",
        "activityBar.inactiveForeground": "#5A544E",
        "activityBarBadge.background": "#d97857",
        "activityBarBadge.foreground": "#FFFFFF",

        "sideBar.background": "#252422",
        "sideBar.foreground": "#d6d5d2",
        "sideBarTitle.foreground": "#8E8880",
        "sideBarSectionHeader.background": "#2a2826",
        "sideBarSectionHeader.foreground": "#d6d5d2",

        "list.activeSelectionBackground": "#d9785720",
        "list.activeSelectionForeground": "#d6d5d2",
        "list.inactiveSelectionBackground": "#383634",
        "list.hoverBackground": "#38363480",
        "list.errorForeground": "#e57777",
        "list.warningForeground": "#fbae60",

        "titleBar.activeBackground": "#252422",
        "titleBar.activeForeground": "#d6d5d2",
        "tab.activeBackground": "#30302e",
        "tab.inactiveBackground": "#252422",
        "tab.activeForeground": "#d6d5d2",
        "tab.inactiveForeground": "#8E8880",
        "tab.border": "#252422",
        "tab.activeBorderTop": "#d97857",

        "statusBar.background": "#252422",
        "statusBar.foreground": "#d6d5d2",

        // --- Terminal ---
        "terminal.background": "#252422",
        "terminal.foreground": "#d6d5d2",
        "terminal.ansiBlack": "#30302e",
        "terminal.ansiRed": "#e57777",
        "terminal.ansiGreen": "#98e361",
        "terminal.ansiYellow": "#fbae60",
        "terminal.ansiBlue": "#70b8ff",
        "terminal.ansiMagenta": "#cc7bf5",
        "terminal.ansiCyan": "#88C0D0",
        "terminal.ansiWhite": "#d6d5d2",

        "input.background": "#383634",
        "input.border": "#423E3A",
        "button.background": "#d97857",
        "button.hoverBackground": "#e88868",
        "focusBorder": "#d9785760"
    },
    "tokenColors": [
        {
            "name": "Comment",
            "scope": ["comment", "punctuation.definition.comment"],
            "settings": {
                "fontStyle": "italic",
                "foreground": "#7D7670"
            }
        },
        {
            "name": "String",
            "scope": ["string", "markup.inserted"],
            "settings": {
                "foreground": "#98e361"
            }
        },
        {
            "name": "Number, Constant",
            "scope": ["constant.numeric", "constant.language", "constant.character"],
            "settings": {
                "foreground": "#88B0B0"
            }
        },
        {
            "name": "Keyword, Storage",
            "scope": ["keyword", "storage.type", "storage.modifier"],
            "settings": {
                "foreground": "#cc7bf5"
            }
        },
        {
            "name": "Function",
            "scope": ["entity.name.function", "meta.function-call", "support.function"],
            "settings": {
                "foreground": "#70b8ff"
            }
        },
        {
            "name": "Class, Type",
            "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"],
            "settings": {
                "foreground": "#fbae60"
            }
        },
        {
            "name": "Operator, Punctuation",
            "scope": ["keyword.operator", "punctuation"],
            "settings": {
                "foreground": "#A7A299"
            }
        },
        {
            "name": "Variable",
            "scope": ["variable", "variable.other"],
            "settings": {
                "foreground": "#d6d5d2"
            }
        }
    ]
}